		C1GT F 1 Offset(-18,32)
		C1GT GHI 1 Offset(-18,32)
		C1GT J 1 A_PlaySound("Chaingun/RotatorEquip", 7)
		C1GT K 1 Offset(-19,32)
		C1GT L 1 Offset(-20,32)
		C1GT L 1 Offset(-20,32)
		C1GT L 1 Offset(-20,32)
		C1GT L 1 Offset(-20,32)
